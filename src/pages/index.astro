16" d="M203.279 96.0341L212.351 95.3135L212.807 101.063L211.607 101.159L211.252 96.6928L208.601 96.9034L208.902 100.699L207.702 100.795L207.401 96.9988L204.581 97.2227L204.936 101.689L203.736 101.784L203.279 96.0341Z" fill="#7B7B7B"></path><path id="Vector_17" d="M202.042 87.5295L207.057 89.5062L211.043 86.1885L211.279 87.696L208.271 90.1094L211.874 91.4857L212.093 92.8826L207.216 90.9693L203.114 94.3619L202.877 92.8544L205.999 90.3524L202.261 88.9264L202.042 87.5295Z" fill="#7B7B7B"></path><path id="Vector_18" d="M200.43 80.8174L209.267 78.6475L210.643 84.2491L209.473 84.5362L208.405 80.1854L205.822 80.8197L206.73 84.5179L205.561 84.805L204.652 81.1068L201.906 81.7812L202.974 86.1319L201.805 86.419L200.43 80.8174Z" fill="#7B7B7B"></path></g><g id="THINK" class="ReflectionVisual_phaseText__gnV_t ReflectionVisual_phaseThink__I2__W"><path id="Vector_19" d="M9.84823 93.9326L0.858154 92.5224L1.05775 91.25L5.45597 91.9399L1.63917 87.5433L1.88866 85.9528L4.97757 89.5691L10.8896 87.2938L10.6596 88.7599L5.87821 90.6032L7.25398 92.2219L10.0478 92.6602L9.84823 93.9326Z" fill="#7B7B7B"></path><path id="Vector_20" d="M9.16444 101.713L0.0930175 100.992L0.214971 99.4571L7.18327 96.5979L0.484379 96.0658L0.578616 94.8795L9.65004 95.6001L9.54915 96.8701L2.02945 99.9523L9.25868 100.527L9.16444 101.713Z" fill="#7B7B7B"></path><path id="Vector_21" d="M9.1 109.37L7.896 109.37L7.896 107.046L1.204 107.046L1.204 109.37L9.53674e-07 109.37L-2.59471e-07 103.434L1.204 103.434L1.204 105.758L7.896 105.758L7.896 103.434L9.1 103.434L9.1 109.37Z" fill="#7B7B7B"></path><path id="Vector_22" d="M9.64979 117.202L0.578372 117.923L0.476374 116.639L4.32824 116.333L4.04664 112.788L0.194771 113.094L0.0927732 111.81L9.16419 111.089L9.26619 112.373L5.24686 112.693L5.52846 116.238L9.5478 115.918L9.64979 117.202Z" fill="#7B7B7B"></path><path id="Vector_23" d="M10.4165 122.494L2.61588 123.718L3.07147 126.622L1.88202 126.809L0.77124 119.727L1.9607 119.541L2.41629 122.445L10.2169 121.221L10.4165 122.494Z" fill="#7B7B7B"></path></g></g></svg></div></div></div></div></div></div></div></div><div class="line line-right" style="--line-color:#2A2A2A;--dash-size:3px;--dash-gap:4px"></div></div><div class="flash-end-wrapper"></div></section></div><section class="post-dark-section"><img src="images/flash_end.webp" alt="" loading="lazy" decoding="async" class="flash-end"><div class="Container_container__tbJnt"><div class="OneTwoCU_oneTwoCu__8el0W OneTwoCU_imageRight__VUp65 OneTwoCU_noBorders__WM4UP"><div class="OneTwoCU_imageWrapper__qX3mt"><div class="hover-3d fair-billing-image"><div class="hover-3d-card"><img src="images/super-agent-card.webp" alt="super agents card illustration" loading="lazy" decoding="async" class="super-agent-card-image"><div class="glow"></div></div></div></div><div class="OneTwoCU_sectionContent___m0gx"><div class="OneTwoCU_sectionHeader__jNoW1"><span class="OneTwoCU_sectionEyebrow__9Em9P">SUPER FAIR BILLING POLICY</span><h3 class="section-title OneTwoCU_sectionTitle__Wd9I1">When we optimize, you save $</h3><p class="section-description OneTwoCU_sectionDescription__AYRML">When our teams save on AI costs, we pass them onto you. When sudden increases in AI costs occur as a result of new models or other changes, we subsidize the cost so you don't see any sudden increases on credit usage.</p></div></div></div></div></section><section class="cta-final" id="pricing-section"><div class="cta-final-card"><div class="cta-gradient-bg"><img src="images/gradient-bg.webp" alt="gradient background" loading="lazy" decoding="async"><div class="noise-overlay"></div></div><div class="cta-final-content"><h2 class="cta-final-title">Try Super<br>Agents today</h2><div data-testid="cu-action-button"><button data-testid="cu-button" type="button" class="v5 CuButtonV5_button__SDlee button-regular Btn_btn__PviQE CTAFinalCard_ctaDesktopButton__6lSSX" product":"ai-agents","agent-detail":"1"}"=""><span>Get started</span></button></div></div><div class="characters-container"><img src="images/character-left.webp" alt="Character Left" class="character character-1" loading="lazy" decoding="async"><img src="images/character-2.webp" alt="Character 2" class="character character-2" loading="lazy" decoding="async"><img src="images/character-center.webp" alt="Character Center" class="character character-center" loading="lazy" decoding="async"><img src="images/character-4.webp" alt="Character 4" class="character character-4" loading="lazy" decoding="async"><img src="images/character-right.webp" alt="Character Right" class="character character-5" loading="lazy" decoding="async"></div><div class="btn-container"><div data-testid="cu-action-button"><button data-testid="cu-button" type="button" class="v5 CuButtonV5_button__SDlee button-regular Btn_btn__PviQE CTAFinalCard_ctaMobileButton__Rlpm8" product":"ai-agents","agent-detail":"1"}"=""><span>Get started</span></button></div></div></div></section></main></div><footer data-testid="footer" class="CuFooter_wrapper__u8bSx" id="footer"><div class="row justify-between align-center CuFooter_container__6XMFs"><div class="CuFooter_copyrightLockup__QevWk"><span>© <!-- -->2026<!-- --> TheClaws</span></div><div class="row CuFooter_legalLinks__GLY6J"><a data-testid="cu-link" class="CuLink_link__CFBMW" rel="" target="" href="#">Status</a><a data-testid="cu-link" class="CuLink_link__CFBMW" rel="" target="" href="#">Security</a><a data-testid="cu-link" class="CuLink_link__CFBMW" rel="" target="" href="#">Privacy</a><a data-testid="cu-link" class="CuLink_link__CFBMW" rel="" target="" href="#">Terms</a></div></div></footer><div class="" data-testid="cu-sign-up-overlay"></div><div class="" data-testid="cu-contact-sales-modal"></div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Smooth scroll for nav links
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', (e) => {
      const target = document.querySelector(a.getAttribute('href'));
      if (!target) return;
      e.preventDefault();
      const y = target.getBoundingClientRect().top + window.scrollY - 80;
      window.scrollTo({ top: y, behavior: 'smooth' });
    });
  });

  // === HERO: Sync bubbles to character position ===
  function syncBubbles() {
    const actor = document.querySelector('.AgentHeroPin_actor__YseDE');
    const stage = document.querySelector('.CanvaStage_canvaStage__ACZ2c');
    const bubbles = document.querySelectorAll('.bubble');
    if (!actor || !stage || bubbles.length === 0) return;

    const ar = actor.getBoundingClientRect();
    const sr = stage.getBoundingClientRect();

    // Exact ratios captured from current working positions
    const positions = [
      { left: 0.188, top: 0.072 },  // tl
      { left: 0.694, top: 0.072 },  // tr
      { left: 0.094, top: 0.267 },  // ml
      { left: 0.779, top: 0.267 },  // mr
      { left: 0.164, top: 0.457 },  // bl
      { left: 0.719, top: 0.458 },  // br
    ];
    // Skip JS positioning on mobile — CSS handles it
    if (window.innerWidth <= 800) return;

    const bubbleSize = ar.width * 0.139;

    bubbles.forEach((bubble, i) => {
      if (!positions[i]) return;
      const p = positions[i];
      bubble.style.left = (ar.left - sr.left + ar.width * p.left) + 'px';
      bubble.style.top = (ar.top - sr.top + ar.height * p.top) + 'px';
      bubble.style.width = bubbleSize + 'px';
    });
  }
  // === HERO: Sync CTA to character position ===
  function syncCTA() {
    const actor = document.querySelector('.AgentHeroPin_actor__YseDE');
    const stage = document.querySelector('.CanvaStage_canvaStage__ACZ2c');
    const cta = document.querySelector('.AgentHeroPin_ctaWrapper__Hzo48');
    if (!actor || !stage || !cta) return;

    const ar = actor.getBoundingClientRect();
    const sr = stage.getBoundingClientRect();

    // Position CTA at 75% down the character (waist/lower body)
    const ctaY = ar.top - sr.top + ar.height * 0.75;
    cta.style.top = ctaY + 'px';
  }

  syncBubbles();
  syncCTA();
  window.addEventListener('resize', () => { syncBubbles(); syncCTA(); });
  window.addEventListener('load', () => { syncBubbles(); syncCTA(); });

  // === EXPANDABLE TAGS ===
  document.querySelectorAll('[data-expandable-tag]').forEach(tag => {
    tag.addEventListener('click', () => {
      const expanded = tag.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('[data-expandable-tag][aria-expanded="true"]').forEach(t => {
        if (t !== tag) t.setAttribute('aria-expanded', 'false');
      });
      tag.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    });
  });

  // === EXPANDABLE PILLS — click to expand + dialog typewriter + image swap ===
  const pillTexts = {
    "send-email": "I'll write an email to our vendor to ensure we're on track.",
    "direct-message": "Message me like any teammate for 1:1 assistance.",
    "assign-task": "Assign me to a task so I can get to work and keep you updated.",
    "schedule-events": "Tag me in anywhere and I'll schedule events for you.",
    "mentions": "@Mention me in tasks, docs, and chats to ask anything."
  };
  const pillImages = {
    "send-email": "/images/email_dummy.webp",
    "direct-message": "/images/ai-agent-tab-image-chat.webp",
    "assign-task": "/images/ai-agent-tab-image-assign.webp",
    "schedule-events": "/images/ai-agent-tab-image-events.webp",
    "mentions": "/images/ai-agent-tab-image-mentions.webp"
  };
  let pillTypeInterval = null;

  function activatePill(pill) {
    // Collapse others
    document.querySelectorAll('[data-expandable-pill][aria-expanded="true"]').forEach(p => {
      if (p !== pill) p.setAttribute('aria-expanded', 'false');
    });
    pill.setAttribute('aria-expanded', 'true');

    const visualId = pill.getAttribute('data-visual-id');
    const showcase = pill.closest('[data-pill-showcase]');
    if (!showcase || !visualId) return;

    // Swap image
    const img = showcase.querySelector('.showcase-image');
    if (img && pillImages[visualId]) img.src = pillImages[visualId];

    // Typewriter on dialog
    const textEl = showcase.querySelector('.dialog-text');
    const dialogBox = showcase.querySelector('.agent-dialog');
    if (textEl && dialogBox && pillTexts[visualId]) {
      if (pillTypeInterval) clearInterval(pillTypeInterval);
      const words = pillTexts[visualId].split(/(\s+)/);
      textEl.innerHTML = words.map(w => '<span style="visibility:hidden">' + w + '</span>').join('');
      gsap.fromTo(dialogBox, {y: 30, opacity: 0}, {y: 0, opacity: 1, duration: 0.3, ease: 'power2.out'});
      let wordIdx = 0;
      const spans = textEl.querySelectorAll('span');
      pillTypeInterval = setInterval(() => {
        if (wordIdx >= spans.length) { clearInterval(pillTypeInterval); pillTypeInterval = null; return; }
        spans[wordIdx].style.visibility = 'visible';
        wordIdx++;
      }, 60);
    }
  }

  document.querySelectorAll('[data-expandable-pill]').forEach(pill => {
    pill.addEventListener('click', () => activatePill(pill));
  });

  // Auto-activate first pill on scroll into view
  const pillShowcase = document.querySelector('[data-pill-showcase]');
  if (pillShowcase) {
    const firstPill = pillShowcase.querySelector('[data-expandable-pill]');
    const pillObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && firstPill) {
          activatePill(firstPill);
          pillObs.disconnect();
        }
      });
    }, { threshold: 0.3 });
    pillObs.observe(pillShowcase);
  }

  // === CAPABILITIES TABS ===
  const capItems = document.querySelectorAll('.cap-list-item');
  const capMedia = document.querySelectorAll('.cap-media');
  const capDetails = document.querySelectorAll('.cap-details');
  let capIdx = 0, capUserClicked = false;

  function switchCap(idx) {
    capItems.forEach((el, i) => el.classList.toggle('active', i === idx));
    capMedia.forEach((el, i) => {
      el.classList.toggle('active', i === idx);
      gsap.set(el, { opacity: i === idx ? 1 : 0 });
    });
    capDetails.forEach((el, i) => {
      el.classList.toggle('active', i === idx);
      gsap.set(el, { opacity: i === idx ? 1 : 0, pointerEvents: i === idx ? 'auto' : 'none' });
    });
    capIdx = idx;
  }

  capItems.forEach((el, i) => {
    el.addEventListener('click', () => { capUserClicked = true; switchCap(i); });
  });

  if (capItems.length > 0) {
    const revealContainer = document.querySelector('.reveal-container');
    if (revealContainer) {
      ScrollTrigger.create({
        trigger: revealContainer,
        start: 'top top',
        end: '+=100%',
        scrub: true,
        onUpdate(self) {
          // Apply power2.inOut to get the actual clip percentage (how much dark section is visible)
          const p = self.progress;
          const clipPct = p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2;
          // Only start switching caps once 30% of the dark section is visible
          if (clipPct < 0.3) {
            if (capIdx !== 0) switchCap(0);
            return;
          }
          const adjustedPct = (clipPct - 0.3) / 0.7;
          const newIdx = Math.min(
            Math.round(adjustedPct * (capItems.length - 1)),
            capItems.length - 1
          );
          if (newIdx !== capIdx) switchCap(newIdx);
        }
      });
    }
  }

  // === CAROUSEL — transform-based (matches original) ===
  const track = document.querySelector('[data-carousel-track]');
  const carouselSection = document.querySelector('#agent-carousel-section');
  const carouselContainer = track?.closest('[class*="carouselContainer"]');
  const navBtns = document.querySelectorAll('[class*="AgentCarousel_navBtn"]');
  const carouselHeader = carouselSection?.querySelector('[class*="CUSectionHeader"]');
  const carouselCards = document.querySelectorAll('.AgentCarousel_carouselCard__kfTd9');

  let currentX = 0;
  let bounds = { minX: 0, maxX: 0 };
  const cardStep = (window.innerWidth <= 640 ? 230 : 320) + 16;

  function getBounds() {
    if (!track || !carouselContainer) return;
    const cs = getComputedStyle(carouselContainer);
    const pl = parseFloat(cs.paddingLeft), pr = parseFloat(cs.paddingRight);
    bounds.minX = -(track.scrollWidth - (carouselContainer.offsetWidth - pl - pr));
    bounds.maxX = 0;
  }

  function clampX(x) { return Math.max(bounds.minX, Math.min(bounds.maxX, x)); }

  function snapToCard(x) { return -Math.round(Math.abs(x) / cardStep) * cardStep; }

  function updateNavBtns() {
    if (navBtns.length < 2) return;
    const [prev, next] = Array.from(navBtns);
    const prevDisabled = currentX >= bounds.maxX;
    const nextDisabled = currentX <= bounds.minX;
    prev.toggleAttribute('disabled', prevDisabled);
    prev.classList.toggle('AgentCarousel_disabled__Y_TX3', prevDisabled);
    next.toggleAttribute('disabled', nextDisabled);
    next.classList.toggle('AgentCarousel_disabled__Y_TX3', nextDisabled);
  }

  function animateTo(x) {
    currentX = clampX(x);
    gsap.to(track, { x: currentX, duration: 0.5, ease: 'power2.out', overwrite: true });
    updateNavBtns();
  }

  if (track && carouselContainer) {
    getBounds();
    gsap.set(track, { x: 0 });
    // Recalculate after images load to get correct scrollWidth
    window.addEventListener('load', () => { getBounds(); updateNavBtns(); });

    if (navBtns.length >= 2) {
      const [prev, next] = Array.from(navBtns);
      prev.addEventListener('click', () => animateTo(snapToCard(currentX) + cardStep));
      next.addEventListener('click', () => animateTo(snapToCard(currentX) - cardStep));
      updateNavBtns();
    }

    // Wheel: only handle horizontal trackpad swipes (deltaX), never trap vertical scroll
    if (carouselSection) {
      carouselSection.addEventListener('wheel', (e) => {
        if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return;
        e.preventDefault();
        const newX = clampX(currentX - e.deltaX);
        if (newX !== currentX) {
          currentX = newX;
          gsap.to(track, { x: currentX, duration: 0.3, ease: 'power2.out', overwrite: true });
          updateNavBtns();
        }
      }, { passive: false });
    }

    // Mouse drag
    let isDragging = false, dragStartX = 0, dragStartCurrentX = 0;
    track.addEventListener('mousedown', (e) => {
      isDragging = true;
      dragStartX = e.clientX;
      dragStartCurrentX = currentX;
      track.style.cursor = 'grabbing';
    });
    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      currentX = clampX(dragStartCurrentX + (e.clientX - dragStartX));
      gsap.set(track, { x: currentX });
      updateNavBtns();
    });
    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      track.style.cursor = 'grab';
      animateTo(snapToCard(currentX));
    });

    window.addEventListener('resize', () => {
      getBounds();
      currentX = clampX(currentX);
      gsap.set(track, { x: currentX });
      updateNavBtns();
    });
  }

  // === CAROUSEL ANIMATIONS (IntersectionObserver) ===
  if (carouselHeader) {
    const hObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          gsap.fromTo(carouselHeader, { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out' });
          hObs.disconnect();
        }
      });
    }, { threshold: 0.1 });
    hObs.observe(carouselHeader);
  }

  if (carouselCards.length > 0 && carouselSection) {
    const cObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          carouselCards.forEach((card, i) => {
            gsap.fromTo(card, { opacity: 0, y: 60 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.15 + 0.1 * i, ease: 'power2.out' });
          });
          cObs.disconnect();
        }
      });
    }, { threshold: 0.05 });
    cObs.observe(carouselSection);
  }

  // === SCROLL REVEALS ===
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
        revealObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.technology-section, .security-section, .feature-section, .last-feature-section').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(40px)';
    el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
    revealObserver.observe(el);
  });

  // === CTA SECTION — fade in + counter (from reference) ===
  const ctaCounter = document.querySelector('.CTAVibe_statsNumber__f58ZD');
  const ctaVibeEl = document.querySelector('.CTAVibe_ctaVibe__5fxKv');
  if (ctaCounter && ctaVibeEl) {
    let counterVal = 10239432;
    ScrollTrigger.create({
      trigger: ctaVibeEl,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        gsap.fromTo(ctaVibeEl, {opacity:0, y:40}, {opacity:1, y:0, duration:0.8, ease:'power2.out'});
        const tick = () => {
          counterVal += 2.3 * (0.5 + 1.5 * Math.random());
          ctaCounter.textContent = Math.floor(counterVal).toLocaleString();
          setTimeout(tick, 200 * Math.random() + 200);
        };
        tick();
        // Dot grid scrolling animation
        const grids = ctaVibeEl.querySelectorAll('.CTAVibe_dotGrid__8w17I');
        if (grids.length === 2) {
          const g1 = grids[0], g2 = grids[1];
          const h = g1.offsetHeight;
          gsap.set(g1, {y: 0});
          gsap.set(g2, {y: h});
          const wrap = gsap.utils.wrap(-h, h);
          gsap.to(g1, {y: '-=' + (2*h), duration: 20, ease: 'none', repeat: -1, modifiers: {y: v => wrap(parseFloat(v)) + 'px'}});
          gsap.to(g2, {y: '-=' + (2*h), duration: 20, ease: 'none', repeat: -1, modifiers: {y: v => wrap(parseFloat(v)) + 'px'}});
          const dots1 = g1.querySelectorAll('span');
          const dots2 = g2.querySelectorAll('span');
          setInterval(() => {
            const idx = Math.floor(Math.random() * dots1.length);
            gsap.to(dots1[idx], {backgroundColor: '#DBE0E5', duration: 0.3, ease: 'power2.out'});
            gsap.to(dots2[idx], {backgroundColor: '#DBE0E5', duration: 0.3, ease: 'power2.out'});
          }, 500);
        }
      }
    });
  }

  // === MARQUEE REVEAL (white section clips away revealing dark section) ===
  const marqueeSection = document.querySelector('.marquee-section');
  const revealContainer = marqueeSection?.parentElement;
  if (marqueeSection && revealContainer && window.innerWidth >= 990) {
    gsap.set(marqueeSection, { clipPath: 'inset(-1px -1px 0 -1px)' });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: revealContainer,
        start: 'top top',
        end: '+=100%',
        anticipatePin: 1,
        pin: true,
        scrub: true,
        invalidateOnRefresh: true
      }
    });

    tl.to(marqueeSection, {
      clipPath: 'inset(-1px -1px calc(100% + 1px) -1px)',
      ease: 'power2.inOut',
      duration: 1
    }, 0);

    tl.to(marqueeSection, { scale: 1.1, ease: 'power2.in', duration: 0.5 }, 0);
    tl.to(marqueeSection, { scale: 1, ease: 'power2.out', duration: 0.5 }, 0.5);

    // Flash gradient sweep (from bottom to top during reveal)
    const revealFlash = document.querySelector('.reveal-flash');
    if (revealFlash) {
      const mh = marqueeSection.offsetHeight;
      gsap.set(revealFlash, { top: mh, yPercent: -50, opacity: 1 });
      tl.fromTo(revealFlash, { top: mh, opacity: 1 }, { top: 0, opacity: 1, ease: 'power2.inOut', duration: 1 }, 0);
      tl.to(revealFlash, { height: 800, ease: 'power2.in', duration: 0.5 }, 0);
      tl.to(revealFlash, { height: 450, ease: 'power2.out', duration: 0.5 }, 0.5);
    }
  }

  // === SCROLL-TRIGGERED CLASS TOGGLES ===
  function onVisible(sel, cb) {
    const el = document.querySelector(sel);
    if (!el) return;
    new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) cb(el); });
    }, { threshold: 0.3 }).observe(el);
  }
  onVisible('[class*="SyncVisual_syncVisual"]', el => {
    el.classList.add('SyncVisual_inView__3jK1K');
    // Count 0→2706 over 2.5s with 1s delay, cubic ease-out
    const numEl = el.querySelector('[class*="SyncVisual_syncNumber"]');
    if (numEl) {
      const start = performance.now();
      const countUp = (now) => {
        const elapsed = now - start - 1000;
        if (elapsed < 0) { requestAnimationFrame(countUp); return; }
        const t = Math.min(elapsed / 2500, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        numEl.textContent = Math.floor(2706 * eased).toLocaleString();
        if (t < 1) requestAnimationFrame(countUp);
      };
      requestAnimationFrame(countUp);
    }
  });
  onVisible('[class*="KnowledgeVisual_knowledgeVisual"]', el => el.classList.add('KnowledgeVisual_inView__wK3mP'));

  // === ANALYTICS CARD — count 0→40%, fill bars, arrow fly ===
  const analyticsCard = document.querySelector('.analytics-card');
  if (analyticsCard) {
    const percentEl = analyticsCard.querySelector('.analytics-percent');
    const barBlocks = analyticsCard.querySelectorAll('.bar-block');
    const arrow = analyticsCard.querySelector('.analytics-arrow');
    const targetVal = parseInt(percentEl?.getAttribute('data-target') || '40');

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (arrow) arrow.classList.remove('stopped');
          const start = performance.now();
          const animate = (now) => {
            const t = Math.min((now - start) / 2000, 1);
            const eased = 1 - Math.pow(1 - t, 3);
            const current = Math.round(targetVal * eased);
            if (percentEl) percentEl.childNodes[0].textContent = current;
            const activeBars = Math.round((current / 100) * barBlocks.length);
            barBlocks.forEach((bar, i) => bar.classList.toggle('active', i < activeBars));
            if (t < 1) requestAnimationFrame(animate);
          };
          requestAnimationFrame(animate);
          obs.disconnect();
        }
      });
    }, { threshold: 0.5 });
    obs.observe(analyticsCard);
  }

  // === AMBIENT CARD — line chart reveal (2s) + counter (21.3K→25.0K slow) + dot shuffle ===
  const ambientCard = document.querySelector('.ambient-card');
  if (ambientCard) {
    const valueEl = ambientCard.querySelector('.ambient-value');
    const clipRect = ambientCard.querySelector('.clip-rect');
    const dotChart = ambientCard.querySelector('.dot-chart');

    const ambientObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // 1. Line chart reveal: 0→100 over 2 seconds, cubic ease-out
          if (clipRect) {
            const start = performance.now();
            const animateChart = (now) => {
              const t = Math.min((now - start) / 2000, 1);
              const eased = 100 * (1 - Math.pow(1 - t, 3));
              clipRect.setAttribute('width', String(eased));
              if (t < 1) requestAnimationFrame(animateChart);
            };
            requestAnimationFrame(animateChart);
          }

          // 2. Questions counter: +1 every 32ms, 21300→25000
          let count = 21300;
          const counterInterval = setInterval(() => {
            if (count >= 25000) { clearInterval(counterInterval); return; }
            count += 1;
            if (valueEl) valueEl.textContent = (count / 1000).toFixed(1) + 'K';
          }, 32);

          // 3. Dot chart: fill width with columns, then scroll-left every 700ms
          if (dotChart) {
            // Fill chart to full width (containerWidth / 16 columns)
            const totalCols = Math.max(1, Math.floor(dotChart.offsetWidth / 16));
            while (dotChart.children.length < totalCols) {
              const col = document.createElement('div');
              col.className = 'dot-col';
              const n = Math.floor(Math.random() * 7) + 1;
              for (let i = 0; i < n; i++) col.appendChild(document.createElement('span'));
              dotChart.appendChild(col);
            }
            // Scroll-left: prepend new, remove last
            setInterval(() => {
              const newCol = document.createElement('div');
              newCol.className = 'dot-col';
              const n = Math.floor(Math.random() * 7) + 1;
              for (let i = 0; i < n; i++) newCol.appendChild(document.createElement('span'));
              dotChart.prepend(newCol);
              if (dotChart.children.length > totalCols) dotChart.removeChild(dotChart.lastElementChild);
            }, 700);
          }

          ambientObs.disconnect();
        }
      });
    }, { threshold: 0.3 });
    ambientObs.observe(ambientCard);
  }

  // === PRIVACY VISUAL — matrix-style character scramble ===
  const privacyVisual = document.querySelector('[class*="PrivacyVisual_privacyVisual"]');
  if (privacyVisual) {
    const charset = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/=<>?';
    const rows = privacyVisual.querySelectorAll('[class*="PrivacyVisual_privacyRow"]');
    const privateRowClass = 'PrivacyVisual_privateRow__pkaNy';
    const highlightClass = 'PrivacyVisual_highlight__SWmNr';

    const privObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Scramble characters every 200ms for 4 seconds
          let scrambleCount = 0;
          const scrambleInterval = setInterval(() => {
            scrambleCount++;
            if (scrambleCount > 20) { clearInterval(scrambleInterval); return; }
            rows.forEach(row => {
              if (row.classList.contains(privateRowClass)) return;
              const spans = row.querySelectorAll('span');
              spans.forEach(span => {
                span.textContent = charset[Math.floor(Math.random() * charset.length)];
                if (Math.random() < 0.05) {
                  span.classList.add(highlightClass);
                } else {
                  span.classList.remove(highlightClass);
                }
              });
            });
          }, 200);
          privObs.disconnect();
        }
      });
    }, { threshold: 0.3 });
    privObs.observe(privacyVisual);
  }

  // === ZERO RETENTION SHIELD — mouse spotlight + code scramble ===
  const shieldContainer = document.querySelector('[class*="ZeroRetentionVisual_zeroRetentionVisual"]');
  const codeLayer = document.querySelector('[class*="ZeroRetentionVisual_codeTextLayer"]');
  const shieldSvg = document.querySelector('[class*="ZeroRetentionVisual_shieldOverlay"]');
  if (shieldContainer && codeLayer) {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789<>{}[]();:/\\|!@#$%^&*-+=_';
    const randomText = (len) => { let s=''; for(let i=0;i<len;i++) s+=chars[Math.floor(Math.random()*chars.length)]; return s; };
    codeLayer.textContent = randomText(2500);

    const rect = shieldContainer.getBoundingClientRect;
    let mouseX = 0.5, mouseY = 0.5; // normalized 0-1
    let curX = 0.5, curY = 0.5;
    let isHovering = false;
    let frameCount = 0;

    shieldContainer.addEventListener('mousemove', (e) => {
      const r = shieldContainer.getBoundingClientRect();
      mouseX = (e.clientX - r.left) / r.width;
      mouseY = (e.clientY - r.top) / r.height;
    });
    shieldContainer.addEventListener('mouseenter', () => {
      isHovering = true;
      codeLayer.style.color = 'rgba(255,255,255,0.6)';
    });
    shieldContainer.addEventListener('mouseleave', () => {
      isHovering = false;
      mouseX = 0.5; mouseY = 0.5;
      codeLayer.style.color = 'rgba(255,255,255,0.25)';
    });

    (function raf() {
      curX += (mouseX - curX) * 0.1;
      curY += (mouseY - curY) * 0.1;
      const r = shieldContainer.getBoundingClientRect();
      const px = curX * r.width;
      const py = curY * r.height;
      shieldContainer.style.setProperty('--x', px + 'px');
      shieldContainer.style.setProperty('--y', py + 'px');
      codeLayer.style.setProperty('--x', px + 'px');
      codeLayer.style.setProperty('--y', py + 'px');
      if (shieldSvg) {
        const sx = (curX - 0.5) * 15;
        const sy = (curY - 0.5) * 15;
        shieldSvg.style.transform = 'translate(' + sx + 'px,' + sy + 'px)';
      }
      if (isHovering && ++frameCount >= 15) {
        frameCount = 0;
        codeLayer.textContent = randomText(2500);
      }
      requestAnimationFrame(raf);
    })();
  }

  // === PERMISSIONS VISUAL — scanner line follows mouse, splits ASCII/normal agent ===
  const permCenter = document.querySelector('[class*="PermissionsVisual_permissionsCenter"]');
  if (permCenter) {
    const containerWidth = permCenter.offsetWidth || 450;
    let targetX = containerWidth / 2;
    let currentX = containerWidth / 2;

    permCenter.addEventListener('mousemove', (e) => {
      const r = permCenter.getBoundingClientRect();
      targetX = e.clientX - r.left;
    });
    permCenter.addEventListener('mouseleave', () => {
      targetX = containerWidth / 2;
    });

    // Canvas for scanner glow line
    const glowCanvas = permCenter.querySelector('canvas[class*="PermissionsVisual_scannerGlow"]');
    const ctx = glowCanvas ? glowCanvas.getContext('2d') : null;
    if (glowCanvas) {
      glowCanvas.width = containerWidth * 2;
      glowCanvas.height = (permCenter.offsetHeight || 400) * 2;
      glowCanvas.style.width = containerWidth + 'px';
      glowCanvas.style.height = (permCenter.offsetHeight || 400) + 'px';
    }

    // Pre-render particle sprite (purple/white radial glow)
    const particleCanvas = document.createElement('canvas');
    particleCanvas.width = 16; particleCanvas.height = 16;
    const pCtx = particleCanvas.getContext('2d');
    const pGrad = pCtx.createRadialGradient(8,8,0,8,8,8);
    pGrad.addColorStop(0, 'rgba(255,255,255,1)');
    pGrad.addColorStop(0.3, 'rgba(196,181,253,0.8)');
    pGrad.addColorStop(0.7, 'rgba(139,92,246,0.4)');
    pGrad.addColorStop(1, 'transparent');
    pCtx.fillStyle = pGrad;
    pCtx.beginPath(); pCtx.arc(8,8,8,0,Math.PI*2); pCtx.fill();

    // Create 150 particles
    const ratio2 = glowCanvas ? glowCanvas.width / containerWidth : 1;
    const scanH = glowCanvas ? glowCanvas.height : 400;
    const scanParticles = [];
    for (let i = 0; i < 150; i++) {
      scanParticles.push({
        x: containerWidth / 2 * ratio2 + (Math.random() - 0.5) * 3,
        y: Math.random() * scanH,
        vx: (0.5 * Math.random() + 0.15) * ratio2,
        vy: (Math.random() - 0.5) * 0.2 * ratio2,
        radius: (2.5 * Math.random() + 1.5) * ratio2,
        alpha: 0.4 * Math.random() + 0.6,
        originalAlpha: 0.4 * Math.random() + 0.6,
        life: 1,
        decay: 0.01 * Math.random() + 0.003,
        time: 0,
        twinkleSpeed: 0.06 * Math.random() + 0.02,
        twinkleAmount: 0.15 * Math.random() + 0.1
      });
    }

    (function scanLoop() {
      currentX += (targetX - currentX) * 0.08;
      permCenter.style.setProperty('--scanner-x', currentX + 'px');

      // Draw scanner glow (matching reference: line + purple glow + particles)
      if (ctx && glowCanvas) {
        const w = glowCanvas.width;
        const h = glowCanvas.height;
        const ratio = w / containerWidth;
        const x = currentX * ratio;
        ctx.clearRect(0, 0, w, h);
        ctx.globalCompositeOperation = 'lighter';

        // 1. Thin white center line (3px)
        const lineGrad = ctx.createLinearGradient(x - 1.5 * ratio, 0, x + 1.5 * ratio, 0);
        lineGrad.addColorStop(0, 'rgba(255,255,255,0)');
        lineGrad.addColorStop(0.3, 'rgba(255,255,255,0.9)');
        lineGrad.addColorStop(0.5, 'rgba(255,255,255,1)');
        lineGrad.addColorStop(0.7, 'rgba(255,255,255,0.9)');
        lineGrad.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.globalAlpha = 1;
        ctx.fillStyle = lineGrad;
        ctx.fillRect(x - 1.5 * ratio, 0, 3 * ratio, h);

        // 2. Purple inner glow (12px)
        const innerGlow = ctx.createLinearGradient(x - 6 * ratio, 0, x + 6 * ratio, 0);
        innerGlow.addColorStop(0, 'rgba(139,92,246,0)');
        innerGlow.addColorStop(0.5, 'rgba(196,181,253,0.8)');
        innerGlow.addColorStop(1, 'rgba(139,92,246,0)');
        ctx.globalAlpha = 0.8;
        ctx.fillStyle = innerGlow;
        ctx.fillRect(x - 6 * ratio, 0, 12 * ratio, h);

        // 3. Purple outer glow (24px)
        const outerGlow = ctx.createLinearGradient(x - 12 * ratio, 0, x + 12 * ratio, 0);
        outerGlow.addColorStop(0, 'rgba(139,92,246,0)');
        outerGlow.addColorStop(0.5, 'rgba(139,92,246,0.4)');
        outerGlow.addColorStop(1, 'rgba(139,92,246,0)');
        ctx.globalAlpha = 0.6;
        ctx.fillStyle = outerGlow;
        ctx.fillRect(x - 12 * ratio, 0, 24 * ratio, h);

        // 4. Vertical fade mask (fade top/bottom 40px)
        ctx.globalCompositeOperation = 'destination-in';
        ctx.globalAlpha = 1;
        const fadeMask = ctx.createLinearGradient(0, 0, 0, h);
        fadeMask.addColorStop(0, 'rgba(255,255,255,0)');
        fadeMask.addColorStop(40 * ratio / h, 'rgba(255,255,255,1)');
        fadeMask.addColorStop(1 - 40 * ratio / h, 'rgba(255,255,255,1)');
        fadeMask.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = fadeMask;
        ctx.fillRect(0, 0, w, h);
        // 5. Floating particles
        ctx.globalCompositeOperation = 'lighter';
        scanParticles.forEach(p => {
          p.time += p.twinkleSpeed;
          const twinkle = Math.sin(p.time) * p.twinkleAmount;
          p.alpha = Math.max(0, p.originalAlpha + twinkle);
          p.x += p.vx;
          p.y += p.vy;
          p.life -= p.decay;
          if (p.x > w + 50 || p.life <= 0) {
            p.x = x + (Math.random() - 0.5) * 3 * ratio;
            p.y = Math.random() * h;
            p.vx = (0.5 * Math.random() + 0.15) * ratio;
            p.vy = (Math.random() - 0.5) * 0.2 * ratio;
            p.life = 1;
          }
          ctx.globalAlpha = p.alpha * p.life;
          ctx.drawImage(particleCanvas, p.x - p.radius, p.y - p.radius, p.radius * 2, p.radius * 2);
        });
        ctx.globalCompositeOperation = 'source-over';
      }

      requestAnimationFrame(scanLoop);
    })();
  }

  // === HOVER 3D CARD — tilt + glow on mouse move ===
  document.querySelectorAll('.hover-3d-card').forEach(card => {
    const glowEl = card.querySelector('.glow');
    const parent = card.closest('.hover-3d');

    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const offsetX = x - rect.width / 2;
      const offsetY = y - rect.height / 2;
      const dist = Math.sqrt(offsetX ** 2 + offsetY ** 2);
      const angle = 2 * Math.log(Math.max(dist, 1));

      card.style.transform = 'scale3d(1.05,1.05,1.05) rotate3d(' + (offsetY / 100) + ',' + (-offsetX / 100) + ',0,' + angle + 'deg)';

      if (glowEl) {
        glowEl.style.backgroundImage = 'radial-gradient(circle at ' + (2 * offsetX + rect.width / 2) + 'px ' + (2 * offsetY + rect.height / 2) + 'px, rgba(255,255,255,0.3), rgba(0,0,0,0.06))';
      }
    });

    card.addEventListener('mouseleave', () => {
      card.style.transform = 'rotate3d(0)';
      if (glowEl) glowEl.style.backgroundImage = '';
    });
  });

  // === AUDIT LOG AUTO-SCROLL ===
  const auditTrack = document.querySelector('[class*="AuditLogVisual_auditLogTrack"]');
  if (auditTrack) {
    let pos = 0;
    setInterval(() => { pos += 0.5; auditTrack.style.transform = `translateY(-${pos % 400}px)`; }, 50);
  }
</script>

